{
    "name": "grobinson3108/laravel-rag-pipeline",
    "description": "Production-grade RAG pipeline for Laravel: dense vector search (ChromaDB) + knowledge graph (Neo4j) + Cohere reranking + multi-tier query cache + LLM-based query classifier. Extracted from production chatbot SaaS.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "rag",
        "retrieval-augmented-generation",
        "vector-search",
        "knowledge-graph",
        "neo4j",
        "chromadb",
        "cohere",
        "reranking",
        "openai",
        "embeddings",
        "ai",
        "llm",
        "chatbot"
    ],
    "authors": [
        {
            "name": "Greg Robinson",
            "email": "greg@audelalia.fr",
            "homepage": "https://audelalia.fr"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "guzzlehttp/guzzle": "^7.0",
        "laudis/neo4j-php-client": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Grobinson3108\\LaravelRagPipeline\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Grobinson3108\\LaravelRagPipeline\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "Grobinson3108\\LaravelRagPipeline\\RagPipelineServiceProvider"
            ]
        }
    }
}
